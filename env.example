# ============================================================
# Cold Outreach Pipeline — Environment Variables
# Copy this to .env and fill in your real API keys.
# NEVER commit the real .env to version control.
# ============================================================

# ── API Keys ─────────────────────────────────────────────────
APOLLO_API_KEY=your_apollo_api_key_here
PROSPEO_API_KEY=your_prospeo_api_key_here
BREVO_API_KEY=your_brevo_api_key_here
OPENAI_API_KEY=sk-your_openai_key_here

# ── Sender Identity (must be verified in Brevo) ──────────────
SENDER_NAME=Your Full Name
SENDER_EMAIL=you@yourdomain.com

# ── Pipeline Tuning (optional — sensible defaults provided) ──
MAX_SIMILAR_COMPANIES=25
MAX_CONTACTS_PER_COMPANY=5
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_SECONDS=30

# ── Prospeo Rate-Limit Buffer ────────────────────────────────
# Prospeo free tier requires a pause between search and bulk enrich.
# 90–120 seconds is safe; set to 0 if you have a paid plan.
PROSPEO_ENRICH_DELAY_SECONDS=90

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/pipeline.log

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_MODEL=gpt-4o-mini
EMAIL_MAX_WORDS=120
